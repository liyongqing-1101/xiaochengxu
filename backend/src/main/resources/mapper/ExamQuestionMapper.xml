<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wxjiaozi.mapper.ExamQuestionMapper">

    <resultMap id="ExamQuestionResultMap" type="com.wxjiaozi.entity.ExamQuestion">
        <id column="id" property="id"/>
        <result column="subject_id" property="subjectId"/>
        <result column="type" property="type"/>
        <result column="stem" property="stem"/>
        <result column="option_list" property="optionList" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="answer" property="answer"/>
        <result column="explanation" property="explanation"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createTime"/>
        <result column="updated_at" property="updateTime"/>
    </resultMap>

    <select id="selectPageWithFilters" resultMap="ExamQuestionResultMap">
        SELECT
            id, subject_id, type, stem, option_list, answer, explanation, status, created_at, updated_at
        FROM exam_question
        <where>
            <if test="subjectId != null">
                AND subject_id = #{subjectId}
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND stem LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <!-- 按科目和题型统计题量（过滤禁用状态） -->
    <select id="countBySubjectAndType" resultType="java.util.HashMap">
        SELECT
            type,
            COUNT(*) AS count
        FROM exam_question
        WHERE subject_id = #{subjectId}
          AND status = 1
        GROUP BY type
    </select>

    <!-- 随机抽题：按科目+题型随机抽取指定数量的题目（过滤禁用状态） -->
    <select id="selectRandomBySubjectAndType" resultMap="ExamQuestionResultMap">
        SELECT
            id, subject_id, type, stem, option_list, answer, explanation, status, created_at, updated_at
        FROM exam_question
        WHERE subject_id = #{subjectId}
          AND type = #{type}
          AND status = 1
        ORDER BY RAND()
        LIMIT #{limit}
    </select>

</mapper>
