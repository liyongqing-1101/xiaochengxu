<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wxjiaozi.mapper.ExamQuestionMapper">

    <!-- ============================================================ -->
    <!-- ResultMap：包含JSON字段option_list的类型处理器 -->
    <!-- 仅保留表中实际存在的字段 -->
    <!-- ============================================================ -->
    <resultMap id="ExamQuestionResultMap" type="com.wxjiaozi.entity.ExamQuestion">
        <id column="id" property="id"/>
        <result column="subject_id" property="subjectId"/>
        <result column="type" property="type"/>
        <result column="stem" property="stem"/>
        <!-- JSON字段：选项数组 -->
        <result column="option_list" property="optionList"
                typeHandler="com.wxjiaozi.handler.JsonTypeHandler"/>
        <result column="answer" property="answer"/>
        <result column="explanation" property="explanation"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- ============================================================ -->
    <!-- 基础列：仅查询实际存在字段 -->
    <!-- ============================================================ -->
    <sql id="Base_Column_List">
        id, subject_id, type, stem, option_list, answer, explanation, status, created_at, updated_at
    </sql>

    <!-- ============================================================ -->
    <!-- 1. 根据ID查询题目 -->
    <!-- ============================================================ -->
    <select id="selectById" resultMap="ExamQuestionResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM exam_question
        WHERE id = #{id, javaType=Long, jdbcType=BIGINT}
    </select>

    <!-- ============================================================ -->
    <!-- 2. 分页查询题目列表（简化筛选条件） -->
    <!-- 仅保留：科目ID、题型、状态、关键词 -->
    <!-- ============================================================ -->
    <select id="selectPageWithFilters" resultMap="ExamQuestionResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM exam_question
        <where>
            <if test="subjectId != null">
                AND subject_id = #{subjectId, javaType=Long, jdbcType=BIGINT}
            </if>
            <if test="type != null">
                AND type = #{type, javaType=Integer, jdbcType=INTEGER}
            </if>
            <if test="status != null">
                AND status = #{status, javaType=Integer, jdbcType=INTEGER}
            </if>
            <if test="keyword != null and keyword != ''">
                AND stem LIKE CONCAT('%', #{keyword, javaType=String, jdbcType=VARCHAR}, '%')
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{offset, javaType=int, jdbcType=INTEGER}, #{limit, javaType=int, jdbcType=INTEGER}
    </select>

    <!-- ============================================================ -->
    <!-- 3. 统计符合条件的题目总数 -->
    <!-- ============================================================ -->
    <select id="countWithFilters" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM exam_question
        <where>
            <if test="subjectId != null">
                AND subject_id = #{subjectId, javaType=Long, jdbcType=BIGINT}
            </if>
            <if test="type != null">
                AND type = #{type, javaType=Integer, jdbcType=INTEGER}
            </if>
            <if test="status != null">
                AND status = #{status, javaType=Integer, jdbcType=INTEGER}
            </if>
            <if test="keyword != null and keyword != ''">
                AND stem LIKE CONCAT('%', #{keyword, javaType=String, jdbcType=VARCHAR}, '%')
            </if>
        </where>
    </select>

    <!-- ============================================================ -->
    <!-- 4. 插入单条题目（简化字段） -->
    <!-- 判断题自动将option_list设为NULL，避免JSON序列化空值问题 -->
    <!-- ============================================================ -->
    <insert id="insert" parameterType="com.wxjiaozi.entity.ExamQuestion" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO exam_question (
            subject_id,
            type,
            stem,
            option_list,
            answer,
            explanation,
            status,
            created_at,
            updated_at
        ) VALUES (
            #{subjectId, javaType=Long, jdbcType=BIGINT},
            #{type, javaType=Integer, jdbcType=INTEGER},
            #{stem, javaType=String, jdbcType=VARCHAR},
            <choose>
                <when test="type == 3">NULL</when>
                <when test="optionList == null or optionList.size() == 0">NULL</when>
                <otherwise>#{optionList, typeHandler=com.wxjiaozi.handler.JsonTypeHandler, jdbcType=VARCHAR}</otherwise>
            </choose>,
            #{answer, javaType=String, jdbcType=VARCHAR},
            #{explanation, javaType=String, jdbcType=VARCHAR},
            #{status, javaType=Integer, jdbcType=INTEGER},
            NOW(),
            NOW()
        )
    </insert>

    <!-- ============================================================ -->
    <!-- 5. 批量插入题目（Excel导入专用，简化字段） -->
    <!-- 判断题自动将option_list设为NULL -->
    <!-- ============================================================ -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO exam_question (
            subject_id,
            type,
            stem,
            option_list,
            answer,
            explanation,
            status,
            created_at,
            updated_at
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.subjectId, javaType=Long, jdbcType=BIGINT},
                #{item.type, javaType=Integer, jdbcType=INTEGER},
                #{item.stem, javaType=String, jdbcType=VARCHAR},
                <!-- 判断题option_list自动设为NULL -->
                <choose>
                    <when test="item.type == 3">NULL</when>
                    <otherwise>#{item.optionList, typeHandler=com.wxjiaozi.handler.JsonTypeHandler}</otherwise>
                </choose>,
                #{item.answer, javaType=String, jdbcType=VARCHAR},
                #{item.explanation, javaType=String, jdbcType=VARCHAR},
                1,
                NOW(),
                NOW()
            )
        </foreach>
    </insert>

    <!-- ============================================================ -->
    <!-- 6. 更新题目（简化字段） -->
    <!-- 判断题自动将option_list设为NULL，避免JSON序列化空值问题 -->
    <!-- ============================================================ -->
    <update id="updateById" parameterType="com.wxjiaozi.entity.ExamQuestion">
        UPDATE exam_question
        <set>
            <if test="subjectId != null">subject_id = #{subjectId, javaType=Long, jdbcType=BIGINT},</if>
            <if test="type != null">type = #{type, javaType=Integer, jdbcType=INTEGER},</if>
            <if test="stem != null">stem = #{stem, javaType=String, jdbcType=VARCHAR},</if>
            <if test="type == 3">option_list = NULL,</if>
            <if test="type != 3 and optionList != null and optionList.size() > 0">
                option_list = #{optionList, typeHandler=com.wxjiaozi.handler.JsonTypeHandler, jdbcType=VARCHAR},
            </if>
            <if test="answer != null">answer = #{answer, javaType=String, jdbcType=VARCHAR},</if>
            <if test="explanation != null">explanation = #{explanation, javaType=String, jdbcType=VARCHAR},</if>
            <if test="status != null">status = #{status, javaType=Integer, jdbcType=INTEGER},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id, javaType=Long, jdbcType=BIGINT}
    </update>

    <!-- ============================================================ -->
    <!-- 7. 删除题目 -->
    <!-- ============================================================ -->
    <delete id="deleteById">
        DELETE FROM exam_question
        WHERE id = #{id, javaType=Long, jdbcType=BIGINT}
    </delete>

    <!-- ============================================================ -->
    <!-- 8. 批量删除题目 -->
    <!-- ============================================================ -->
    <delete id="batchDeleteByIds">
        DELETE FROM exam_question
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id, javaType=Long, jdbcType=BIGINT}
        </foreach>
    </delete>

    <!-- ============================================================ -->
    <!-- 9. 批量查询题目 -->
    <!-- ============================================================ -->
    <select id="selectByIds" resultMap="ExamQuestionResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM exam_question
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id, javaType=Long, jdbcType=BIGINT}
        </foreach>
    </select>

    <!-- ============================================================ -->
    <!-- 10. 查询所有激活题目 -->
    <!-- ============================================================ -->
    <select id="selectAllActive" resultMap="ExamQuestionResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM exam_question
        WHERE status = 1
        ORDER BY id DESC
    </select>

    <!-- ============================================================ -->
    <!-- 11. 按科目和题型统计题量（小程序首页显示） -->
    <!-- ============================================================ -->
    <select id="countBySubjectAndType" resultType="java.util.Map">
        SELECT type, COUNT(*) as count
        FROM exam_question
        WHERE subject_id = #{subjectId}
          AND status = 1
        GROUP BY type
        ORDER BY type
    </select>

    <!-- ============================================================ -->
    <!-- 12. 根据偏移量查询单条题目（每日一题） -->
    <!-- ============================================================ -->
    <select id="selectByOffset" resultMap="ExamQuestionResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM exam_question
        WHERE status = 1
        ORDER BY id
        LIMIT #{offset}, 1
    </select>

    <!-- ============================================================ -->
    <!-- 13. 按科目和题型随机抽题 -->
    <!-- ============================================================ -->
    <select id="selectRandomBySubjectAndType" resultMap="ExamQuestionResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM exam_question
        WHERE subject_id = #{subjectId}
          AND status = 1
          <if test="type != null">
              AND type = #{type}
          </if>
        ORDER BY RAND()
        LIMIT #{limit}
    </select>

    <!-- ============================================================ -->
    <!-- 14. 查询所有题目用于去重（仅返回必要字段） -->
    <!-- ============================================================ -->
    <select id="selectAllForDeduplication" resultMap="ExamQuestionResultMap">
        SELECT id, stem
        FROM exam_question
    </select>

    <!-- ============================================================ -->
    <!-- 15. 统计指定科目和状态的题目数量 -->
    <!-- ============================================================ -->
    <select id="countBySubjectAndStatus" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM exam_question
        WHERE subject_id = #{subjectId}
          AND status = #{status}
    </select>

</mapper>
