<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wxjiaozi.mapper.ExamQuestionMapper">

    <resultMap id="ExamQuestionResultMap" type="com.wxjiaozi.entity.ExamQuestion">
        <id column="id" property="id"/>
        <result column="category_id" property="categoryId"/>
        <result column="subject_id" property="subjectId"/>
        <result column="chapter_id" property="chapterId"/>
        <result column="tag_id" property="tagId"/>
        <result column="type" property="type"/>
        <result column="stem" property="stem"/>
        <result column="option_a" property="optionA"/>
        <result column="option_b" property="optionB"/>
        <result column="option_c" property="optionC"/>
        <result column="option_d" property="optionD"/>
        <result column="answer" property="answer"/>
        <result column="explanation" property="explanation"/>
        <result column="difficulty" property="difficulty"/>
        <result column="status" property="status"/>
        <result column="stem_images" property="stemImages"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectPageWithFilters" resultMap="ExamQuestionResultMap">
        SELECT
            id, category_id, subject_id, chapter_id, tag_id,
            type, stem, option_a, option_b, option_c, option_d,
            answer, explanation, difficulty, status, stem_images,
            created_at, updated_at
        FROM exam_question
        <where>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="subjectId != null">
                AND subject_id = #{subjectId}
            </if>
            <if test="chapterId != null">
                AND chapter_id = #{chapterId}
            </if>
            <if test="tagId != null">
                AND tag_id = #{tagId}
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
            <if test="difficulty != null">
                AND difficulty = #{difficulty}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND stem LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <insert id="insertBatch" parameterType="list">
        INSERT INTO exam_question (
            category_id, subject_id, chapter_id, tag_id,
            type, stem, option_a, option_b, option_c, option_d,
            answer, explanation, difficulty, status, stem_images
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.categoryId},
                #{item.subjectId},
                #{item.chapterId},
                #{item.tagId},
                #{item.type},
                #{item.stem},
                #{item.optionA},
                #{item.optionB},
                #{item.optionC},
                #{item.optionD},
                #{item.answer},
                #{item.explanation},
                #{item.difficulty},
                #{item.status},
                #{item.stemImages}
            )
        </foreach>
    </insert>

</mapper>
