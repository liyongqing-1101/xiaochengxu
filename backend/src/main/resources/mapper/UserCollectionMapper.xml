<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wxjiaozi.mapper.UserCollectionMapper">

    <resultMap id="BaseResultMap" type="com.wxjiaozi.entity.UserCollection">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="question_id" property="questionId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, question_id, created_at
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_collection
        WHERE id = #{id}
    </select>

    <select id="selectByUserIdAndQuestionId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_collection
        WHERE user_id = #{userId} AND question_id = #{questionId}
    </select>

    <select id="selectByUserIdWithPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_collection
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
        LIMIT #{offset, javaType=int, jdbcType=INTEGER}, #{pageSize, javaType=int, jdbcType=INTEGER}
    </select>

    <select id="countByUserId" resultType="java.lang.Long">
        SELECT COUNT(*) FROM user_collection WHERE user_id = #{userId}
    </select>

    <insert id="insert" parameterType="com.wxjiaozi.entity.UserCollection" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_collection (user_id, question_id, created_at)
        VALUES (#{userId}, #{questionId}, NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM user_collection WHERE id = #{id}
    </delete>

</mapper>
