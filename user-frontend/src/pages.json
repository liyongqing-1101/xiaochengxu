{
  "easycom": {
    "autoscan": true,
    "custom": {}
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "高校教资题库",
        "navigationStyle": "custom",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/study/index",
      "style": {
        "navigationBarTitleText": "学习",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/teaching-aid/index",
      "style": {
        "navigationBarTitleText": "教辅"
      }
    },
    {
      "path": "pages/community/index",
      "style": {
        "navigationBarTitleText": "社区"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationStyle": "custom"
      }
    }
  ],
  "subPackages": [
    {
      "root": "subpackages/answer",
      "pages": [
        {
          "path": "pages/index",
          "style": {
            "navigationBarTitleText": "答题",
            "navigationStyle": "custom",
            "disableScroll": true
          }
        }
      ]
    },
    {
      "root": "subpackages/wrong-book",
      "pages": [
        {
          "path": "pages/index",
          "style": {
            "navigationBarTitleText": "错题本"
          }
        }
      ]
    },
    {
      "root": "subpackages/profile",
      "pages": [
        {
          "path": "pages/favorites",
          "style": {
            "navigationBarTitleText": "我的收藏"
          }
        },
        {
          "path": "pages/history",
          "style": {
            "navigationBarTitleText": "练习记录"
          }
        },
        {
          "path": "pages/settings",
          "style": {
            "navigationBarTitleText": "设置"
          }
        }
      ]
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["subpackages/answer"]
    },
    "pages/study/index": {
      "network": "wifi",
      "packages": ["subpackages/answer", "subpackages/wrong-book", "subpackages/profile"]
    }
  },
  "tabBar": {
    "custom": true,
    "color": "#999999",
    "selectedColor": "#4A90D9",
    "list": [
      { "pagePath": "pages/index/index", "text": "首页" },
      { "pagePath": "pages/study/index", "text": "学习" },
      { "pagePath": "pages/teaching-aid/index", "text": "教辅" },
      { "pagePath": "pages/community/index", "text": "社区" },
      { "pagePath": "pages/profile/index", "text": "我的" }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "高校教资题库",
    "backgroundColor": "#F5F7FA",
    "backgroundTextStyle": "light"
  }
}
